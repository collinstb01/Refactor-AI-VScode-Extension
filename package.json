{
    "name": "refactor-ai",
    "displayName": "Refactor AI VSCode Extension",
    "description": "AI-powered workspace analyzer",
    "version": "1.0.0",
    "publisher": "refactor-ai",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "refactorAi.analyzeWorkspace",
                "title": "Refactor AI: Analyze Workspace"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "axios": "^1.5.0"
    }
}